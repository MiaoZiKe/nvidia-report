<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Andy Ke | Portfolio & Resume</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Noto Sans TC', sans-serif; background-color: #0f172a; color: #e2e8f0; }
        .tech-card:hover { border-color: #22c55e; transform: translateY(-5px); transition: all 0.3s; }
        .gradient-text { background: linear-gradient(90deg, #22c55e, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
</head>
<body class="leading-relaxed">

    <header class="py-20 text-center bg-slate-900 border-b border-slate-800">
        <div class="container mx-auto px-4">
            <h1 class="text-5xl font-bold mb-4 gradient-text">柯成橋 Andy Ke</h1>
            <p class="text-xl text-slate-400 mb-6">Senior Firmware & System Engineer | Process Engineer</p>
            <div class="flex justify-center space-x-4">
                <span class="bg-slate-800 px-4 py-2 rounded-full text-sm font-mono text-green-400 border border-green-500/30">Master in Optics & Photonics</span>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 py-12 max-w-4xl">
        
        <section class="mb-16">
            <h2 class="text-2xl font-bold mb-8 border-l-4 border-green-500 pl-4 uppercase tracking-wider">Work Experience</h2>
            <div class="space-y-8">
                <div class="relative pl-8 border-l border-slate-700 pb-1">
                    <div class="absolute w-4 h-4 bg-green-500 rounded-full -left-2 top-1 shadow-[0_0_10px_#22c55e]"></div>
                    <h3 class="text-xl font-bold">TSMC | Process Engineer</h3>
                    <p class="text-green-400 text-sm mb-2">Apr. 2025 – Present</p>
                </div>

                <div class="relative pl-8 border-l border-slate-700 pb-1">
                    <div class="absolute w-4 h-4 bg-slate-500 rounded-full -left-2 top-1"></div>
                    <h3 class="text-xl font-bold">ASUS | Senior System Engineer</h3>
                    <p class="text-slate-400 text-sm mb-2">Aug. 2023 – Apr. 2025</p>
                </div>

                <div class="relative pl-8 border-l border-slate-700 pb-1">
                    <div class="absolute w-4 h-4 bg-slate-500 rounded-full -left-2 top-1"></div>
                    <h3 class="text-xl font-bold">ASUS | Firmware Engineer</h3>
                    <p class="text-slate-400 text-sm mb-2">Aug. 2022 – Jun. 2023</p>
                </div>
                
                <div class="relative pl-8 border-l border-slate-700">
                    <div class="absolute w-4 h-4 bg-slate-500 rounded-full -left-2 top-1"></div>
                    <h3 class="text-xl font-bold">Electronic Tutor & School Teacher</h3>
                    <p class="text-slate-400 text-sm">Earlier Career</p>
                </div>
            </div>
        </section>

        <div class="grid md:grid-cols-2 gap-8 mb-16">
            <section class="bg-slate-800/50 p-6 rounded-2xl border border-slate-700 tech-card">
                <h2 class="text-xl font-bold mb-4 flex items-center"><i class="fas fa-graduation-cap mr-2 text-green-500"></i> Education</h2>
                <ul class="space-y-3 text-slate-300">
                    <li><strong class="text-white">National Central University (NCU)</strong><br>Master in Optics and Photonics</li>
                    <li><strong class="text-white">National Chin-Yi University (NCUT)</strong><br>Bachelor in Electronic Engineering</li>
                </ul>
            </section>

            <section class="bg-slate-800/50 p-6 rounded-2xl border border-slate-700 tech-card">
                <h2 class="text-xl font-bold mb-4 flex items-center"><i class="fas fa-heart mr-2 text-pink-500"></i> Hobby</h2>
                <div class="flex flex-wrap gap-2">
                    <span class="bg-slate-700 px-3 py-1 rounded text-sm"># Travel</span>
                    <span class="bg-slate-700 px-3 py-1 rounded text-sm"># Dancing</span>
                    <span class="bg-slate-700 px-3 py-1 rounded text-sm"># Tech News</span>
                    <span class="bg-slate-700 px-3 py-1 rounded text-sm"># Work Out</span>
                </div>
            </section>
        </div>

        <div class="text-center">
            <a href="https://miaozike.github.io/nvidia-report/" class="inline-block bg-green-600 hover:bg-green-500 text-white font-bold py-4 px-8 rounded-full transition-all shadow-lg hover:shadow-green-500/20">
                查看我的 NVIDIA 分析報告專案 <i class="fas fa-external-link-alt ml-2"></i>
            </a>
        </div>
    </main>

    <footer class="py-10 text-center text-slate-500 text-sm">
        © 2026 Andy Ke. Built with GitHub Pages & Tailwind CSS.
    </footer>

</body>
</html>
